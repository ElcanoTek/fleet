# Native ACP agent image — the agent-side of fleet's `native-acp` runtime flavor.
#
# fleet (the ACP client) spawns this image via `podman run -i` and drives it over
# ACP stdio. Inside, cmd/fleet-native-agent runs fleet's unified fantasy loop
# (agentcore.Run) AS a sandboxed ACP agent: the loop runs HERE, but it has NO
# local executor — every bash/run_python call (and the run events) ride the ACP
# `_fleet/*` extension methods back to the client, which executes them in the
# host-managed hardened sandbox and applies full governance. There is NO podman
# in this image, so the agent physically cannot self-execute (no
# Podman-in-Podman).
#
# This image is a PER-CLIENT CONFIG-BUNDLE artifact, the same as the execution
# sandbox: it extends the bundle's own sandbox base so the toolchain the loop
# advertises matches what the host actually runs. The base is pinned by the
# sibling sandbox/Containerfile (digest-pinned there); we build FROM the local
# tag that build produces so the lineage stays in one place.
#
# Build (build-on-box default):
#   scripts/build-native-agent-image.sh
#
# The manifest's `runtimes.native-acp.image` names the resulting tag
# (localhost/fleet-native-agent:latest in the generic bundle).

# Build the agent binary in a Go stage, then copy it onto the sandbox base so the
# agent runs over the same toolchain the host sandbox provides. The base tag is
# produced by scripts/build-sandbox-image.sh from the sibling Containerfile
# (digest-pinned there).
ARG SANDBOX_BASE=localhost/fleet-sandbox:latest
ARG GO_BUILDER=docker.io/library/golang:1.26

FROM ${GO_BUILDER} AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/fleet-native-agent ./cmd/fleet-native-agent

FROM ${SANDBOX_BASE}
COPY --from=build /out/fleet-native-agent /usr/local/bin/fleet-native-agent
# The agent speaks ACP over stdio: stdout is the protocol channel, stderr is
# diagnostics (split). No PTY (the client spawns with `-i`, never `-t`).
ENTRYPOINT ["/usr/local/bin/fleet-native-agent"]
