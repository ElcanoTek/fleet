# ACP example-agent image — the TEST PROVIDER for fleet's external (type: acp)
# flavor. Builds cmd/acp-example-agent, a deterministic credential-free external
# ACP agent (a trimmed copy of the coder/acp-go-sdk example agent) that streams a
# turn and issues one session/request_permission.
#
# fleet's ExternalRuntime spawns this via `podman run -i` exactly as it would a
# real provider (Claude Code via the claude-agent-acp bridge, or Goose's native
# `goose acp`) — proving the GENERIC external path end-to-end without any model
# credentials. The live E2E test (FLEET_ACP_EXTERNAL_E2E_IMAGE) drives it.
#
# Build:
#   podman build -f config/default/sandbox/Containerfile.acp-example-agent \
#     -t localhost/fleet-acp-example-agent:latest .
ARG GO_BUILDER=docker.io/library/golang:1.26

FROM ${GO_BUILDER} AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/acp-example-agent ./cmd/acp-example-agent

# A minimal scratch-style base: the example agent self-executes nothing real and
# needs no toolchain. A distroless static base keeps the containment sandbox tiny.
FROM gcr.io/distroless/static-debian12
COPY --from=build /out/acp-example-agent /usr/local/bin/acp-example-agent
# ACP over stdio: stdout is the protocol channel, stderr diagnostics. No PTY.
ENTRYPOINT ["/usr/local/bin/acp-example-agent"]
