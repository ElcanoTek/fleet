    {
      "id": 13,
      "type": "timeseries",
      "title": "Request latency p50 / p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(fleet_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "refId": "A",
          "format": "time_series",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(fleet_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "refId": "B",
          "format": "time_series",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(fleet_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "refId": "C",
          "format": "time_series",
          "legendFormat": "p99"
        }
      ],
      "description": "histogram_quantile over fleet_http_request_duration_seconds_bucket. Buckets cap at 10s (le=+Inf above), so p99 reports +Inf when the tail exceeds 10s.",
