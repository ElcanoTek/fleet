      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "fleet_sandbox_pool_size{instance=~\"$instance\"}",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "description": "Live gauge fleet_sandbox_pool_size \u2014 warm Podman sandbox containers parked and ready in the pool.",
