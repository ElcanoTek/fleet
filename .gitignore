# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.local

# Operator lifecycle runtime artifacts (scripts/bootstrap.sh + scripts/update.sh)
.fleet-state/
.fleet-client/

# cutlass one-shot run workspaces + logs (scripts/run_workflow_live.sh)
.fleet-runs/

# Editor/IDE
# .idea/
# .vscode/

# Python (fleet MCP servers)
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
/internal/tools/data/
/internal/agent/data/

# Node / Next.js (fleet web)
node_modules/
.next/
*.tsbuildinfo
web/test-results/
web/playwright-report/

# Live e2e runtime artifacts (scripts/e2e-boot-server.sh)
.e2e-bin/
.e2e-run/
web/.e2e-live.env
# Stray local fleet runtime files
/fake-llm
/fleet
/fleet-admin
/fleet-bench
/cutlass
fleet-session.json

# Per-run bash audit logs the agent loop writes to CWD during tests.
internal/acpruntime/data/
internal/acpingress/data/

# middle-manager state directory
.middle-manager/
